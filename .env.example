# Tayr Al-Saad API
# ---
# Easiest flow: copy to `.env` (`pnpm setup`), then `pnpm services` + `pnpm dev`.
# Omit or comment REDIS_URL if you are not running Redis (queues disabled).

NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Use 127.0.0.1 (not "localhost") on Windows to avoid resolving to [::1] when Mongo listens on IPv4 only.
MONGODB_URI=mongodb://127.0.0.1:27017/tayralsaad
# Uncomment when Redis is running (e.g. `pnpm services`). Queues/notifications stay off if omitted:
# REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=change-me-at-least-32-chars-long-access
JWT_REFRESH_SECRET=change-me-at-least-32-chars-refresh-xx
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

CORS_ORIGIN=http://localhost:5173

WEB_PUBLIC_URL=http://localhost:5173

# --- Meta WhatsApp Cloud (optional) ---
# Set WHATSAPP_ACCESS_TOKEN + WHATSAPP_PHONE_NUMBER_ID after Meta Business setup.
# BullMQ notifications worker sends live tracking links (needs REDIS_URL).
# Configure Meta webhook GET/POST: https://<your-api-host>/webhooks/whatsapp
# WHATSAPP_VERIFY_TOKEN=<same as Meta “Verify token”>
# META_APP_SECRET=<App secret for optional signature verification>
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
