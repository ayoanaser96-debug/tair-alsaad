# Tayr Al-Saad — API environment
# =========================================================================
# In container/host deployments, set these as real platform env vars.
# For local dev, copy relevant values into the repo-root `.env` (the API
# auto-loads it). Never commit real secrets.

# --- Core runtime ---
NODE_ENV=production                 # development | test | production
PORT=4000                           # Port to listen on (host usually injects this)
HOST=0.0.0.0                        # Bind address; keep 0.0.0.0 for containers/hosts
API_PREFIX=/api/v1                  # Base path for all versioned API routes

# --- Database (required) ---
# Full connection string from your provider (e.g. MongoDB Atlas). No local assumptions.
# Atlas: whitelist the deploy platform egress IPs (or 0.0.0.0/0) in Network Access.
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/tayralsaad?retryWrites=true&w=majority

# --- Redis (optional) ---
# Enables BullMQ notification queue/worker. Omit to disable queues gracefully.
REDIS_URL=redis://:password@host:6379

# --- Auth / JWT (required) ---
# Must be >= 32 chars, strong, unique, and DIFFERENT from each other.
# Production refuses to boot with placeholder values (e.g. "change-me...").
JWT_ACCESS_SECRET=replace-with-a-long-random-32+-char-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-32+-char-string
JWT_ACCESS_TTL_SECONDS=900          # Access token lifetime (default 15m)
JWT_REFRESH_TTL_SECONDS=2592000     # Refresh token lifetime (default 30d)

# --- CORS (required in prod) ---
# Comma-separated allow-list of browser origins (web app + admin). No trailing slash.
# Native mobile app sends no Origin header and is always allowed.
CORS_ORIGIN=https://app.tayralsaad.example,https://admin.tayralsaad.example

# Public URL of the web app (used for building links).
WEB_PUBLIC_URL=https://app.tayralsaad.example

# Absolute base URL of THIS API (used for absolute upload links). Optional.
PUBLIC_API_URL=https://api.tayralsaad.example

# --- Meta WhatsApp Cloud API (optional) ---
# If unset, the notification worker skips WhatsApp sends silently.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=              # Must match the "Verify token" set in Meta webhook config
META_APP_SECRET=                    # App secret for optional webhook signature verification
