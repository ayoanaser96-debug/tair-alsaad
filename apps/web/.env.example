# Backend API (must match server PORT; use http:// for local dev)
VITE_API_URL=http://127.0.0.1:3333
# Production (example): VITE_API_URL=https://api.smartgateapp.com
# Public web app: https://smartgateapp.com
# Socket.io (defaults to ws/wss derived from VITE_API_URL if omitted)
VITE_WS_URL=ws://127.0.0.1:3333
# Mapbox (maps / tracking UI)
VITE_MAPBOX_TOKEN=
# Enable MSW mock API in the browser (run: npx msw init public/ in apps/dashboard)
VITE_USE_MOCKS=false
