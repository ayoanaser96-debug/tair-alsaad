# ─────────────────────────────────────────────────────────────
# Tayr Al-Saad — web app (apps/web) environment
# Copy to `.env` for local dev. In Netlify, set these under
# Site settings → Environment variables. Only VITE_* vars are
# exposed to the browser — never put secrets here.
# ─────────────────────────────────────────────────────────────

# REQUIRED. Base URL of the Express API, including the /api/v1 prefix.
# Local dev:  http://127.0.0.1:4000/api/v1
# Production: the Back4app container URL, e.g. https://tayralsaad-api.b4a.run/api/v1
VITE_API_URL=http://127.0.0.1:4000/api/v1

# OPTIONAL. Socket.IO endpoint. If omitted it is derived from VITE_API_URL
# (http→ws, https→wss). Only set this if the realtime server lives elsewhere.
# VITE_WS_URL=wss://tayralsaad-api.b4a.run

# OPTIONAL. Reserved for future Mapbox tiles. The current tracking map uses
# OpenStreetMap embeds and needs no key — leave blank unless you wire Mapbox.
VITE_MAPBOX_TOKEN=

# OPTIONAL. "true" enables the in-browser MSW mock API (dev only).
# MUST be "false" (or unset) for any real/production build.
VITE_USE_MOCKS=false
