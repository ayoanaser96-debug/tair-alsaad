{
  "name": "@tayralsaad/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "codegen:tokens": "node ./scripts/generate-tailwind-theme.mjs",
    "prestart": "node ./scripts/generate-tailwind-theme.mjs",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "node ./scripts/generate-tailwind-theme.mjs && tsc --noEmit -p tsconfig.json",
    "lint": "eslint app components lib stores --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "eas-build:android": "eas build --platform android --profile production",
    "eas-build:android:preview": "eas build --platform android --profile preview",
    "android:bundle:release": "cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-navigation/native": "^7.0.14",
    "@tanstack/react-query": "^5.62.15",
    "@tayralsaad/i18n": "workspace:*",
    "@tayralsaad/tokens": "workspace:*",
    "@tayralsaad/types": "workspace:*",
    "@tayralsaad/utils": "workspace:*",
    "axios": "^1.7.9",
    "expo": "~52.0.23",
    "expo-asset": "~11.0.5",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.8",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.5",
    "expo-localization": "~16.0.1",
    "expo-location": "~18.0.7",
    "expo-router": "~4.0.17",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "i18next": "^24.2.3",
    "nativewind": "^4.2.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.4.0",
    "react-native": "0.76.6",
    "react-native-css-interop": "0.2.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-maps": "1.18.0",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-worklets-core": "^1.6.3",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@types/node": "^22.13.5",
    "@types/react": "~18.3.18",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~12.0.11",
    "typescript": "~5.6.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@tayralsaad/i18n",
          "@tayralsaad/types",
          "@tayralsaad/tokens",
          "@tayralsaad/utils"
        ]
      }
    }
  }
}
